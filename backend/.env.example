PORT=3001
FRONTEND_URL=http://localhost:5173
DB_PATH=./data/influencers.db
NODE_ENV=development

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Token encryption — REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# First admin account (used by seed script only)
ADMIN_EMAIL=admin@falak.io
ADMIN_PASSWORD=Admin@Falak2026
ADMIN_NAME=Platform Admin

# Social platform OAuth (configure after registering apps on each platform)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# RapidAPI — scraper fallback for public follower counts (no OAuth needed)
RAPIDAPI_KEY=

# Email (nodemailer — add in Phase 12)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@falak.io

# Payments (Stripe — add in Phase 7)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
