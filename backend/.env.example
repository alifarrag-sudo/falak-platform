# ─────────────────────────────────────────────────────────────────────────────
# FALAK PLATFORM — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Public URL of this backend (used for OAuth redirect URIs and email links)
BACKEND_URL=http://localhost:3001

# URL of the frontend (used in CORS allow-list and email links)
FRONTEND_URL=http://localhost:5173

# Path to the SQLite database file
DB_PATH=./data/influencers.db

# Set to "true" on first deploy to seed demo data (Render sets this automatically)
SEED_DEMO=false

# Set to "true" to hide all demo seed records from API responses platform-wide.
# Use this when switching from demo mode to live investor / real-user view.
# Individual routes also support ?demo=false query param for the same effect.
LIVE_VIEW_MODE=false

# ── Security — generate both with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" ──
# JWT signing secret — MUST be changed before any real users log in
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars

# AES encryption key for sensitive token storage — must be exactly 32 characters
TOKEN_ENCRYPTION_KEY=change-this-to-exactly-32-chars!!

# Separate JWT secret for the creator portal (defaults to JWT_SECRET if not set)
PORTAL_JWT_SECRET=change-this-to-a-different-random-string-for-portal

# ── Seed / First Admin Account ────────────────────────────────────────────────
# Used only by the seed-admin script. Change before running seed in production.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-strong-admin-password-here
ADMIN_NAME=Platform Admin

# ── Social OAuth — Instagram / Facebook ──────────────────────────────────────
# Register at: https://developers.facebook.com/apps/
# Required permissions: instagram_basic, instagram_content_publish, pages_read_engagement
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Social OAuth — TikTok ─────────────────────────────────────────────────────
# Register at: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Social OAuth — YouTube / Google ──────────────────────────────────────────
# Register at: https://console.cloud.google.com/apis/credentials
# Required scopes: youtube.readonly, youtube.force-ssl
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Social OAuth — Snapchat ───────────────────────────────────────────────────
# Register at: https://kit.snapchat.com/
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# ── Social OAuth — Twitter / X ────────────────────────────────────────────────
# Register at: https://developer.twitter.com/en/portal/projects-and-apps
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── Ad Network (optional — for custom audience retargeting) ──────────────────
# Meta Marketing API — https://developers.facebook.com/docs/marketing-apis
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# TikTok Ads — https://ads.tiktok.com/marketing_api/
TIKTOK_ACCESS_TOKEN=
TIKTOK_AD_ACCOUNT_ID=

# Snapchat Ads — https://businesshelp.snapchat.com/s/article/api-overview
SNAPCHAT_ACCESS_TOKEN=
SNAPCHAT_AD_ACCOUNT_ID=

# ── RapidAPI — public follower count fallback scraper ────────────────────────
# Get key at: https://rapidapi.com/
RAPIDAPI_KEY=

# ── Email — Nodemailer (SMTP-agnostic) ───────────────────────────────────────
# SendGrid:  SMTP_HOST=smtp.sendgrid.net   SMTP_USER=apikey   SMTP_PASS=SG.xxxx
# Mailgun:   SMTP_HOST=smtp.mailgun.org    SMTP_USER=postmaster@yourdomain.com
# Gmail:     SMTP_HOST=smtp.gmail.com      SMTP_PORT=465      (use App Password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=FALAK Platform
EMAIL_FROM_EMAIL=noreply@yourdomain.com

# ── Stripe — Billing & Escrow ─────────────────────────────────────────────────
# Secret key: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret: run `stripe listen --forward-to localhost:3001/api/billing/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products at https://dashboard.stripe.com/products and paste price IDs:
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── OpenAI — AI Agent features (AI Match, Outreach Writer, Campaign Briefings) ──
# Get key at: https://platform.openai.com/api-keys
# If not set, AI features return demo/stub data gracefully.
OPENAI_API_KEY=sk-...

# ── Phyllo — Audience Intelligence ───────────────────────────────────────────
# Connects creator social accounts; fetches audience demographics, credibility scores.
# Get credentials at: https://app.getphyllo.com/
# If not set, Intelligence page returns demo data gracefully.
PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=
